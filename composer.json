{
  "name": "davidhirtz/yii2-cms",
  "description": "Content management system based on Yii 2.0 framework",
  "license": "proprietary",
  "type": "yii2-extension",
  "homepage": "https://www.github.com/davidhirtz/yii2-cms",
  "authors": [
    {
      "name": "David Hirtz",
      "homepage": "https://www.davidhirtz.com/"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "php": "^8.3",
    "davidhirtz/yii2-media": "next-dev"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^12.5",
    "symfony/browser-kit": "^7.4",
    "symfony/css-selector": "^7.4"
  },
  "autoload": {
    "psr-4": {
      "Hirtz\\Cms\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Hirtz\\Cms\\Tests\\": "tests"
    }
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://asset-packagist.org"
    }
  ],
  "extra": {
    "bootstrap": "Hirtz\\Cms\\Bootstrap"
  },
  "config": {
    "allow-plugins": {
      "yiisoft/yii2-composer": true,
      "phpro/grumphp-shim": true
    }
  },
  "scripts": {
    "phpstan": "phpstan --memory-limit=2G",
    "test": "phpunit"
  }
}
